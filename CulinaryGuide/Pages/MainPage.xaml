<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CulinaryGuide.Pages.MainPage"
             Title="Nearby Food"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- 顶部定位条（使用文字代替图标） -->
        <VerticalStackLayout Grid.Row="0" Padding="10">
            <Label Text="Current Location：" FontSize="14" TextColor="Gray" />
            <HorizontalStackLayout>
                <!-- 动态显示当前位置的标签 -->
                <Label x:Name="CurrentLocationText" 
                       Text="Getting location..." 
                       FontSize="18" 
                       FontAttributes="Bold" />
                <Button Text="Refresh" 
                        BackgroundColor="Transparent" 
                        TextColor="Blue"
                        HorizontalOptions="EndAndExpand"
                        Clicked="RefreshLocation_Clicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- 搜索栏（使用 Emoji 代替搜索图标） -->
        <Frame Grid.Row="1" Padding="5" CornerRadius="10" Margin="10" HasShadow="False" BorderColor="LightGray">
            <HorizontalStackLayout>
                <Label Text="🔍" FontSize="20" Margin="5,0" />
                <Entry Placeholder="Search for restaurants or dishes" ClearButtonVisibility="WhileEditing" />
            </HorizontalStackLayout>
        </Frame>

        <!-- 餐厅列表 -->
        <CollectionView x:Name="RestaurantsCollectionView"
                        Grid.Row="2"
                        ItemsSource="{Binding Restaurants}"
                        Margin="10,0,10,10"
                        SelectionMode="Single"
                        SelectionChanged="OnRestaurantSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Favorite" 
                                           BackgroundColor="LightBlue"
                                           Invoked="OnFavoriteSwipeInvoked" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Padding="10" Margin="0,5" CornerRadius="15" BorderColor="LightGray" HasShadow="False">
                            <Grid ColumnDefinitions="80, *" RowDefinitions="Auto, Auto, Auto">
                                <!-- 餐厅图片：用Frame包裹实现圆角 -->
                                <Frame Grid.RowSpan="3" 
                                       WidthRequest="70" HeightRequest="70" 
                                       CornerRadius="10" Padding="0" 
                                       BackgroundColor="LightGray" 
                                       HasShadow="False"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image Source="{Binding ImageUrl}" 
                                           Aspect="AspectFill"
                                           WidthRequest="70" HeightRequest="70" />
                                </Frame>

                                <!-- 餐厅名称 -->
                                <Label Grid.Column="1" 
                                       Text="{Binding Name}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       Margin="5,0" />

                                <!-- 评分和距离行 -->
                                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="15" Margin="5,0">
                                    <HorizontalStackLayout>
                                        <Label Text="⭐" />
                                        <Label Text="{Binding Rating}" />
                                    </HorizontalStackLayout>
                                    <Label Text="•" TextColor="Gray" />
                                    <Label Text="{Binding Distance}" TextColor="Blue" />
                                </HorizontalStackLayout>

                                <!-- 简短地址 -->
                                <Label Grid.Row="2" Grid.Column="1" 
                                       Text="{Binding ShortAddress}" 
                                       TextColor="Gray"
                                       FontSize="12"
                                       Margin="5,0" />
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>