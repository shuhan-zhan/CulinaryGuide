<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CulinaryGuide.Pages.DetailPage"
             Title="{Binding Restaurant.Name}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="15">

            <!-- 餐厅大图：修正绑定路径 -->
            <Frame CornerRadius="15" Padding="0" HasShadow="False" HeightRequest="200">
                <Image Source="{Binding Restaurant.ImageUrl}"
                       Aspect="AspectFill"
                       HeightRequest="200" />
            </Frame>

            <!-- 名称和收藏按钮（使用文字心形） -->
            <Grid ColumnDefinitions="*, Auto">
                <Label Grid.Column="0" Text="{Binding Restaurant.Name}" FontSize="24" FontAttributes="Bold" />
                <Button Grid.Column="1"
                        x:Name="FavoriteButton"
                        Text="🤍"
                        FontSize="24"
                        BackgroundColor="Transparent"
                        TextColor="Red"
                        Clicked="FavoriteButton_Clicked" />
            </Grid>

            <!-- 评分 -->
            <HorizontalStackLayout Spacing="5">
                <Label Text="⭐" FontSize="20" />
                <Label Text="{Binding Restaurant.Rating}" FontSize="18" />
                <Label Text="(128 Reviews)" TextColor="Gray" FontSize="14" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- 地址 + 电话（使用 Emoji） -->
            <Frame Padding="10" CornerRadius="10" BorderColor="LightGray" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="📍" FontSize="20" />
                        <Label Text="{Binding Restaurant.FullAddress}" FontSize="16" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="📞" FontSize="20" />
                        <Label Text="{Binding Restaurant.Phone}" FontSize="16" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- 营业时间 -->
            <Label Text="Opening Hours" FontSize="18" FontAttributes="Bold" />
            <Label Text="Monday to Sunday 10:00 - 22:00" FontSize="14" TextColor="Gray" />

            <!-- 查看地图按钮 -->
            <Button Text="View Map"
                    BackgroundColor="LightBlue"
                    TextColor="Black"
                    CornerRadius="10"
                    HeightRequest="50"
                    Command="{Binding NavigateToMapCommand}" />

            <!-- 用户评价预览 -->
            <Label Text="New Review" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0" />
            <Frame Padding="10" CornerRadius="10" BorderColor="LightGray">
                <VerticalStackLayout>
                    <HorizontalStackLayout>
                        <Label Text="Student Zhang" FontAttributes="Bold" />
                        <Label Text="⭐ 5.0" Margin="10,0" TextColor="Gold" />
                    </HorizontalStackLayout>
                    <Label Text="The dishes are varied, highly recommended!" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>